{%- liquid
  assign matrix = "1-2-3,4-5-6,7-8-9" | split: ","
  for row in matrix
    assign cells = row | split: "-"
    for cell in cells
      assign val = cell | plus: 0
      if val == 5
        continue
      endif
      if val > 8
        break
      endif
      echo val
      echo " "
    endfor
  endfor
-%}
