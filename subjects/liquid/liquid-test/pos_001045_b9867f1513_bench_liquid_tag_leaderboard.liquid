{%- liquid
  # ════════════════════════════════════════════════════════════════════
  # LEADERBOARD GENERATOR
  # Ranks players by score (higher is better), handles ties.
  # ════════════════════════════════════════════════════════════════════

  assign board = ""

  # For each player, count how many have a strictly higher score = rank - 1
  for player in players
    assign rank = 1
    for other in players
      if other.score > player.score
        assign rank = rank | plus: 1
      endif
    endfor

    # Medal emoji for top 3
    if rank == 1
      assign medal = "[GOLD]"
    elsif rank == 2
      assign medal = "[SILVER]"
    elsif rank == 3
      assign medal = "[BRONZE]"
    else
      assign medal = ""
    endif

    # Win rate
    assign total_games = player.wins | plus: player.losses
    if total_games > 0
      assign win_rate = player.wins | times: 100 | divided_by: total_games
    else
      assign win_rate = 0
    endif

    # Format: "#rank Name - score pts (win_rate%) medal"
    if board != ""
      assign board = board | append: " | "
    endif
    assign board = board | append: "#" | append: rank | append: " " | append: player.name | append: " - " | append: player.score | append: "pts (" | append: win_rate | append: "%)"
    if medal != ""
      assign board = board | append: " " | append: medal
    endif
  endfor

  echo "LEADERBOARD: " | append: board
-%}
