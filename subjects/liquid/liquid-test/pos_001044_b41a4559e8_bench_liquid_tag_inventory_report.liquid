{%- liquid
  # ════════════════════════════════════════════════════════════════════
  # INVENTORY REPORT GENERATOR
  # Processes raw product data, categorizes, and formats a report.
  # ════════════════════════════════════════════════════════════════════

  # Step 1: Parse raw product data (pipe-separated: name|category|price|qty)
  assign raw = "Widget A|electronics|29.99|150,Widget B|electronics|49.99|80,Gadget X|electronics|199.99|12,T-Shirt M|clothing|24.99|200,Jeans L|clothing|59.99|45,Jacket XL|clothing|129.99|15,Hammer|tools|19.99|90,Drill|tools|89.99|30,Wrench Set|tools|34.99|60,Novel ABC|books|14.99|300,Textbook 101|books|79.99|25,Cookbook Pro|books|29.99|100"
  assign rows = raw | split: ","

  # Step 2: Categorize and compute totals
  assign categories = "electronics,clothing,tools,books" | split: ","
  assign grand_total_qty = 0
  assign report_lines = ""

  for cat in categories
    # Per-category accumulators
    assign cat_qty = 0
    assign cat_items = 0
    assign cat_lines = ""

    for row in rows
      assign fields = row | split: "|"
      assign item_cat = fields[1]
      if item_cat == cat
        assign item_name = fields[0]
        assign item_price = fields[2]
        assign item_qty = fields[3] | plus: 0
        assign cat_qty = cat_qty | plus: item_qty
        assign cat_items = cat_items | plus: 1

        # Format: "Name ($price) xQty"
        if cat_lines != ""
          assign cat_lines = cat_lines | append: "; "
        endif
        assign cat_lines = cat_lines | append: item_name | append: " ($" | append: item_price | append: ") x" | append: item_qty
      endif
    endfor

    assign grand_total_qty = grand_total_qty | plus: cat_qty

    # Build category header + items
    assign cat_upper = cat | upcase
    assign cat_summary = cat_upper | append: " [" | append: cat_items | append: " items, " | append: cat_qty | append: " units]: " | append: cat_lines
    if report_lines != ""
      assign report_lines = report_lines | append: " || "
    endif
    assign report_lines = report_lines | append: cat_summary
  endfor

  # Step 3: Final output
  echo "INVENTORY REPORT (" | append: rows.size | append: " products, " | append: grand_total_qty | append: " total units) --- "
  echo report_lines
-%}
