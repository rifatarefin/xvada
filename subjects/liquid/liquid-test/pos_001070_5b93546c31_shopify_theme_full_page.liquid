<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }}{% if page_title %} - {% endif %}{{ shop.name }}</title>

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">

  {{ content_for_header }}
</head>
<body id="template-{{ template }}">
  <div class="page-container">
    <header class="site-header">
      <div class="container">
        <div class="site-header__top">
          <div class="site-header__announcement">
            <p>{{ shop.metafields.theme.announcement_text }}</p>
          </div>
        </div>
        <div class="site-header__main">
          <div class="site-header__logo">
            <a href="/">
              <span class="site-header__logo-text">{{ shop.name }}</span>
            </a>
          </div>
          <nav class="site-header__nav">
            <ul class="site-nav">
              {% for link in linklists.main-menu.links %}
                <li class="site-nav__item">
                  <a href="{{ link.url }}" class="site-nav__link">{{ link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </nav>
          <div class="site-header__actions">
            <a href="/search" class="site-header__icon">
              <span class="icon icon-search"></span>
            </a>
            <a href="/account" class="site-header__icon">
              <span class="icon icon-user"></span>
            </a>
            <a href="/cart" class="site-header__cart">
              <span class="icon icon-cart"></span>
              <span class="cart-count">{{ cart.item_count }}</span>
            </a>
          </div>
        </div>
      </div>
    </header>

    <main id="main" role="main">
      {{ content_for_layout }}
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="site-footer__grid">
          <div class="site-footer__column">
            <h3 class="site-footer__title">{{ shop.name }}</h3>
            <div class="site-footer__content">
              <p>{{ shop.description }}</p>
            </div>
          </div>
          <div class="site-footer__column">
            <h3 class="site-footer__title">Quick Links</h3>
            <ul class="site-footer__menu">
              {% for link in linklists.footer.links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
          <div class="site-footer__column">
            <h3 class="site-footer__title">Contact Us</h3>
            <div class="site-footer__content">
              <p>{{ shop.address.street }}<br>
              {{ shop.address.city }}, {{ shop.address.province }} {{ shop.address.zip }}</p>
              <p>{{ shop.email }}</p>
              <p>{{ shop.phone }}</p>
            </div>
          </div>
          <div class="site-footer__column">
            <h3 class="site-footer__title">Newsletter</h3>
            <form action="/contact#newsletter-signup" method="post" class="site-footer__form">
              <input type="email" name="contact[email]" placeholder="Your email">
              <button type="submit">Subscribe</button>
            </form>
          </div>
        </div>
        <div class="site-footer__bottom">
          <p>&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved. <a href="{{ shop.url }}">Powered by Shopify</a></p>
        </div>
      </div>
    </footer>
  </div>

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
