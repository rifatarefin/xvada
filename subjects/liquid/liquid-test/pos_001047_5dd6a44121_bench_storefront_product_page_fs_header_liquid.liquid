<header class="site-header">
  <div class="container">
    <a href="/" class="logo">{{ shop.name | escape }}</a>
    <nav class="main-nav" role="navigation">
      <ul>
        {%- for link in navigation -%}
          <li{% if link.active %} class="active"{% endif %}>
            <a href="{{ link.url }}">{{ link.title | escape }}</a>
            {%- if link.children.size > 0 -%}
              <ul class="dropdown">
                {%- for child in link.children -%}
                  <li><a href="{{ child.url }}">{{ child.title | escape }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>
    <div class="header-actions">
      <a href="/search" aria-label="Search"><span class="icon-search"></span></a>
      <a href="/cart" class="cart-link">Cart (<span class="cart-count">{{ cart_count | default: 0 }}</span>)</a>
    </div>
  </div>
</header>
