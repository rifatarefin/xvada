{%- comment -%}CMS page with dynamic section rendering — tests dynamic includes heavily{%- endcomment -%}
<!DOCTYPE html>
<html>
<head><title>{{ page.title | escape }} — {{ shop.name }}</title></head>
<body>
  {% render 'header', shop: shop, navigation: navigation, cart_count: 0 %}

  <main class="page-content">
    <h1>{{ page.title }}</h1>

    {% for section in page.sections %}
      <section class="section section--{{ section.type }}" id="section-{{ forloop.index }}">
        {% include section.type, section: section %}
      </section>
    {% endfor %}
  </main>

  {% render 'footer', shop: shop, footer_links: footer_links %}
</body>
</html>
