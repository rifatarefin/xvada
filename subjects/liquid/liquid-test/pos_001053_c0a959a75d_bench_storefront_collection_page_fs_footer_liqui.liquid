<footer class="site-footer">
  <div class="footer-col"><h4>{{ shop.name }}</h4></div>
  <div class="footer-col"><h4>Links</h4><ul>{% for link in footer_links %}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{% endfor %}</ul></div>
  <p>&copy; {{ "now" | date: "%Y" }} {{ shop.name }}</p>
</footer>
