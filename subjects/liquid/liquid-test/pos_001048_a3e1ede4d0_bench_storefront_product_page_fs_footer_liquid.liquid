<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <h4>{{ shop.name }}</h4>
        <p>{{ shop.description | strip_html | truncate: 120 }}</p>
      </div>
      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul>
          {% for link in footer_links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      <div class="footer-col">
        <h4>Contact</h4>
        <p>{{ shop.email }}</p>
        <p>{{ shop.phone }}</p>
        <p>{{ shop.address.street }}<br>{{ shop.address.city }}, {{ shop.address.state }} {{ shop.address.zip }}</p>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {{ "now" | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>
    </div>
  </div>
</footer>
