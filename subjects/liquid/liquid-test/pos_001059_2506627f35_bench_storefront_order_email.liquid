{%- comment -%}Order confirmation email — tests capture, date, and complex nesting{%- endcomment -%}
{% capture email_subject %}Order {{ order.name }} confirmed — {{ shop.name }}{% endcapture %}
<html>
<body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
  <div style="background: #2d3748; color: white; padding: 20px; text-align: center;">
    <h1 style="margin: 0;">{{ shop.name }}</h1>
  </div>

  <div style="padding: 20px;">
    <h2>Thank you for your order, {{ customer.first_name }}!</h2>
    <p>We've received your order and are preparing it for shipment.</p>

    <div style="background: #f7fafc; padding: 15px; border-radius: 8px; margin: 20px 0;">
      <table style="width: 100%;">
        <tr><td><strong>Order:</strong></td><td>{{ order.name }}</td></tr>
        <tr><td><strong>Date:</strong></td><td>{{ order.created_at | date: "%B %e, %Y at %l:%M %p" }}</td></tr>
        <tr><td><strong>Status:</strong></td><td>{{ order.status | capitalize }}</td></tr>
        <tr><td><strong>Payment:</strong></td><td>{{ order.payment_method | capitalize }}</td></tr>
      </table>
    </div>

    <h3>Items Ordered</h3>
    <table style="width: 100%; border-collapse: collapse;">
      <thead>
        <tr style="background: #edf2f7;">
          <th style="padding: 8px; text-align: left;">Item</th>
          <th style="padding: 8px; text-align: center;">Qty</th>
          <th style="padding: 8px; text-align: right;">Each</th>
          <th style="padding: 8px; text-align: right;">Total</th>
        </tr>
      </thead>
      <tbody>
        {% for item in order.line_items %}
          <tr style="border-bottom: 1px solid #e2e8f0;">
            <td style="padding: 8px;">
              {{ item.title | escape }}
              {% if item.variant %}<br><small style="color: #718096;">{{ item.variant }}</small>{% endif %}
              {% if item.properties.size > 0 %}
                <br>
                {% for prop in item.properties %}
                  <small style="color: #718096;">{{ prop.name }}: {{ prop.value | escape }}</small>{% unless forloop.last %}<br>{% endunless %}
                {% endfor %}
              {% endif %}
            </td>
            <td style="padding: 8px; text-align: center;">{{ item.quantity }}</td>
            <td style="padding: 8px; text-align: right;">
              {% assign ed = item.unit_price | divided_by: 100 %}{% assign ec = item.unit_price | modulo: 100 %}
              ${{ ed }}.{% if ec < 10 %}0{% endif %}{{ ec }}
            </td>
            <td style="padding: 8px; text-align: right;">
              {% assign lt = item.unit_price | times: item.quantity %}
              {% assign ltd = lt | divided_by: 100 %}{% assign ltc = lt | modulo: 100 %}
              ${{ ltd }}.{% if ltc < 10 %}0{% endif %}{{ ltc }}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

    <div style="margin-top: 20px; text-align: right;">
      {% assign ord_sd = order.subtotal | divided_by: 100 %}{% assign ord_sc = order.subtotal | modulo: 100 %}
      <p>Subtotal: ${{ ord_sd }}.{% if ord_sc < 10 %}0{% endif %}{{ ord_sc }}</p>
      {% if order.discount_amount > 0 %}
        {% assign disc_d = order.discount_amount | divided_by: 100 %}{% assign disc_c = order.discount_amount | modulo: 100 %}
        <p style="color: #48bb78;">Discount: -${{ disc_d }}.{% if disc_c < 10 %}0{% endif %}{{ disc_c }}</p>
      {% endif %}
      {% assign ship_d = order.shipping | divided_by: 100 %}{% assign ship_c = order.shipping | modulo: 100 %}
      <p>Shipping: {% if order.shipping == 0 %}FREE{% else %}${{ ship_d }}.{% if ship_c < 10 %}0{% endif %}{{ ship_c }}{% endif %}</p>
      {% assign tax_d = order.tax | divided_by: 100 %}{% assign tax_c = order.tax | modulo: 100 %}
      <p>Tax: ${{ tax_d }}.{% if tax_c < 10 %}0{% endif %}{{ tax_c }}</p>
      {% assign tot_d = order.total | divided_by: 100 %}{% assign tot_c = order.total | modulo: 100 %}
      <p style="font-size: 1.2em;"><strong>Total: ${{ tot_d }}.{% if tot_c < 10 %}0{% endif %}{{ tot_c }}</strong></p>
    </div>

    <div style="display: flex; margin-top: 30px; gap: 20px;">
      <div style="flex: 1;">
        <h4>Shipping Address</h4>
        <p>
          {{ order.shipping_address.name }}<br>
          {{ order.shipping_address.line1 }}<br>
          {% if order.shipping_address.line2 %}{{ order.shipping_address.line2 }}<br>{% endif %}
          {{ order.shipping_address.city }}, {{ order.shipping_address.state }} {{ order.shipping_address.zip }}<br>
          {{ order.shipping_address.country }}
        </p>
      </div>
      <div style="flex: 1;">
        <h4>Billing Address</h4>
        <p>
          {{ order.billing_address.name }}<br>
          {{ order.billing_address.line1 }}<br>
          {% if order.billing_address.line2 %}{{ order.billing_address.line2 }}<br>{% endif %}
          {{ order.billing_address.city }}, {{ order.billing_address.state }} {{ order.billing_address.zip }}<br>
          {{ order.billing_address.country }}
        </p>
      </div>
    </div>

    {% if order.note %}
      <div style="background: #fffff0; padding: 12px; border-radius: 4px; margin-top: 20px;">
        <strong>Order Note:</strong> {{ order.note | escape }}
      </div>
    {% endif %}
  </div>

  <div style="background: #f7fafc; padding: 15px; text-align: center; font-size: 12px; color: #718096;">
    <p>Questions? Reply to this email or contact us at {{ shop.email }}</p>
    <p>&copy; {{ "now" | date: "%Y" }} {{ shop.name }} | <a href="{{ shop.url }}">{{ shop.url | remove: "https://" }}</a></p>
  </div>
</body>
</html>
