<div class="product-card">
  <a href="/products/{{ product.handle }}">
    <img src="/images/{{ product.featured_image }}" alt="{{ product.title | escape }}" loading="lazy">
    <h3>{{ product.title | truncate: 45 }}</h3>
    {% assign d = product.price | divided_by: 100 %}{% assign c = product.price | modulo: 100 %}
    {% if product.compare_at_price and product.compare_at_price > product.price %}
      {% assign cd = product.compare_at_price | divided_by: 100 %}{% assign cc = product.compare_at_price | modulo: 100 %}
      <span class="price--sale">${{ d }}.{% if c < 10 %}0{% endif %}{{ c }}</span>
      <span class="price--compare"><s>${{ cd }}.{% if cc < 10 %}0{% endif %}{{ cc }}</s></span>
    {% else %}
      <span class="price">${{ d }}.{% if c < 10 %}0{% endif %}{{ c }}</span>
    {% endif %}
    {% unless product.available %}<span class="badge--soldout">Sold out</span>{% endunless %}
  </a>
</div>
