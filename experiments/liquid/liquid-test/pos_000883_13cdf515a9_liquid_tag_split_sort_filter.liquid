{%- liquid
  assign animals = "zebra, octopus, giraffe, tiger, ant, elephant, bear" | split: ", "
  assign sorted = animals | sort
  assign result = ""
  for a in sorted
    assign len = a | size
    if len > 4
      if result != ""
        assign result = result | append: ", "
      endif
      assign result = result | append: a | append: "(" | append: len | append: ")"
    endif
  endfor
  echo result
-%}
